# AWS Configuration
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# Amazon Bedrock - Nova Model IDs
NOVA_LITE_MODEL_ID=amazon.nova-lite-v2:0
NOVA_SONIC_MODEL_ID=amazon.nova-sonic-v2:0
NOVA_EMBED_MODEL_ID=amazon.nova-embed-multimodal-v1:0

# Nova Act
NOVA_ACT_API_KEY=your_nova_act_api_key
NOVA_ACT_ENDPOINT=https://nova-act.us-east-1.amazonaws.com

# DynamoDB
DYNAMODB_TABLE_USERS=skillforge-users
DYNAMODB_TABLE_SESSIONS=skillforge-sessions
DYNAMODB_TABLE_LEARNING_PATHS=skillforge-learning-paths

# OpenSearch
OPENSEARCH_ENDPOINT=https://your-opensearch-domain.us-east-1.es.amazonaws.com
OPENSEARCH_INDEX_SKILLS=skills-embeddings
OPENSEARCH_INDEX_COURSES=course-embeddings
OPENSEARCH_INDEX_JOBS=job-embeddings

# ElastiCache Redis
REDIS_URL=redis://localhost:6379

# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=your-secret-key-here-change-in-production
CORS_ORIGINS=http://localhost:3000

# Job Market APIs
LINKEDIN_API_KEY=your_linkedin_api_key
INDEED_API_KEY=your_indeed_api_key

# Learning Platform Credentials (for Nova Act automation)
COURSERA_USERNAME=skillforge_automation@yourdomain.com
COURSERA_PASSWORD=your_coursera_password
UDEMY_API_KEY=your_udemy_api_key
LINKEDIN_LEARNING_TOKEN=your_linkedin_learning_token

# Monitoring
SENTRY_DSN=your_sentry_dsn
LOG_LEVEL=INFO